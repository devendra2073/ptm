<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Secure Access</title>
    <style>
        :root {
            --primary-glow: rgba(88, 166, 255, 0.6);
            --bg-color: #080a0c;
            --card-bg: rgba(22, 27, 34, 0.8);
            --accent: #58a6ff;
            --text-main: #ffffff;
            --text-dim: #8b949e;
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            background-image: 
                radial-gradient(circle at 50% -20%, #161b22, transparent),
                radial-gradient(circle at 0% 100%, #0d1117, transparent);
            color: var(--text-main);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .login-container {
            width: 100%;
            max-width: 380px;
            padding: 2rem;
            text-align: center;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #58a6ff, #1f6feb);
            border-radius: 16px;
            margin: 0 auto 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 20px rgba(88, 166, 255, 0.3);
        }

        h2 {
            font-size: 1.5rem;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        p {
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-bottom: 2.5rem;
        }

        .pin-group {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 8px;
            margin-bottom: 3rem;
        }

        .pin-input {
            width: 100%;
            aspect-ratio: 1 / 1.2;
            background: var(--card-bg);
            border: 1px solid #30363d;
            border-radius: 12px;
            color: var(--accent);
            font-size: 1.8rem;
            font-weight: 700;
            text-align: center;
            outline: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            backdrop-filter: blur(10px);
        }

        /* Hide the actual digit briefly to look like a secure PIN */
        .pin-input.secure {
            -webkit-text-security: disc;
        }

        .pin-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 15px var(--primary-glow);
            transform: scale(1.05);
            background: #1c2128;
        }

        .action-btn {
            width: 100%;
            padding: 16px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(90deg, #238636, #2ea043);
            color: white;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: 1px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(35, 134, 54, 0.3);
            transition: transform 0.2s, opacity 0.3s;
        }

        .action-btn:active {
            transform: scale(0.98);
        }

        .action-btn:disabled {
            background: #21262d;
            color: #484f58;
            box-shadow: none;
            opacity: 0.6;
        }

        /* Responsive Fixes */
        @media (max-width: 400px) {
            .pin-group { gap: 6px; }
            .pin-input { font-size: 1.5rem; border-radius: 8px; }
        }
    </style>
</head>
<body>

    <div class="login-container">
        <div class="logo-icon">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        </div>
        
        <h2>System Access</h2>
        <p>Enter 6-digit Security Token</p>

        <div class="pin-group" id="pin-container">
            <input type="password" maxlength="1" inputmode="numeric" class="pin-input">
            <input type="password" maxlength="1" inputmode="numeric" class="pin-input">
            <input type="password" maxlength="1" inputmode="numeric" class="pin-input">
            <input type="password" maxlength="1" inputmode="numeric" class="pin-input">
            <input type="password" maxlength="1" inputmode="numeric" class="pin-input">
            <input type="password" maxlength="1" inputmode="numeric" class="pin-input">
        </div>

        <button id="verify-btn" class="action-btn" disabled>UNLOCK SYSTEM</button>
    </div>

    <script>
        const inputs = document.querySelectorAll('.pin-input');
        const btn = document.getElementById('verify-btn');

        inputs.forEach((input, index) => {
            // Auto-focus first
            if(index === 0) input.focus();

            input.addEventListener('keyup', (e) => {
                const val = e.target.value;
                
                // Clear if not a number
                if (val && !/^\d$/.test(val)) {
                    e.target.value = '';
                    return;
                }

                if (val && index < inputs.length - 1) {
                    inputs[index + 1].focus();
                }
                
                checkAll();
            });

            input.addEventListener('keydown', (e) => {
                if (e.key === 'Backspace' && !e.target.value && index > 0) {
                    inputs[index - 1].focus();
                }
            });
        });

        function checkAll() {
            const code = Array.from(inputs).map(i => i.value).join('');
            btn.disabled = code.length !== 6;
        }

        btn.addEventListener('click', () => {
            const pin = Array.from(inputs).map(i => i.value).join('');
            btn.innerText = "AUTHENTICATING...";
            btn.style.opacity = "0.7";
            
            // Simulation
            fetch("/login",{
              method:"post",
              headers:{
                "Content-Type":"application/json"
              },
              body:JSON.stringify({pin})
            }).then(e=>{
              return e.json()
            }).then(e=>{
              if(e.status){
                location.href="/device"
              }
            })
        });
    </script>
</body>
</html>
